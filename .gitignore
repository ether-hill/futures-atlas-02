# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# sub-app bundles — built from source on every deploy by scripts/build-subapps.sh
# (NOT committed, so two builders can never clobber each other's bundle). The
# remaining zone bundles under public/ (underground-intelligence,
# odds-of-surviving-ai) are NOT ignored — they are hand-authored with no build
# step, so they stay committed.
/public/prism/
/public/quantum-sandbox/
/public/social-composer/
/public/hollow-villages/
/prism/node_modules/
/quantum-sandbox/node_modules/
/social-composer/node_modules/
/social-composer/out/
/prism/dist/
/quantum-sandbox/dist/
/hollow-villages/node_modules/
/hollow-villages/.next/
/hollow-villages/out/
/hollow-villages/vendor/futures-atlas-core/node_modules/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
